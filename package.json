{
  "name": "oficina_backend",
  "version": "1.0.0",
  "description": "",
  "main": "index.js",
  "scripts": {
    "dev": "nodemon --watch src --ext ts --exec tsx src/server.ts",
    "build": "tsc",
    "start": "node dist/server.js",
    "migration:create": "node-pg-migrate create --migrations-dir db/migrations --migration-file-language ts",
    "migration:up": "node-pg-migrate up --migrations-dir db/migrations --database-url-var DATABASE_URL --tsx",
    "migration:down": "node-pg-migrate down --migrations-dir db/migrations --database-url-var DATABASE_URL --tsx",
    "migration:status": "node-pg-migrate up --migrations-dir db/migrations --database-url-var DATABASE_URL --tsx --dry-run",
    "db:seed": "tsx db/seed.ts"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "dependencies": {
    "@neondatabase/serverless": "^1.0.2",
    "@upstash/redis": "^1.37.0",
    "bcryptjs": "^2.4.3",
    "connect-redis": "^9.0.0",
    "cors": "^2.8.6",
    "express": "^5.2.1",
    "express-session": "^1.19.0"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/express-session": "^1.18.0",
    "@types/node": "^25.4.0",
    "dotenv": "^17.3.1",
    "node-pg-migrate": "^7.9.1",
    "nodemon": "^3.1.14",
    "pg": "^8.16.3",
    "ts-node": "^10.9.2",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3"
  }
}
