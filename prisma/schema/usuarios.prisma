model Usuario {
  id        Int      @id @default(autoincrement())
  empresaId Int
  nome      String
  email     String   @unique
  senhaHash String
  ativo     Boolean  @default(true)
  createdAt DateTime @default(now())

  empresa Empresa @relation(fields: [empresaId], references: [id], onDelete: Cascade)

  @@map("usuarios")
}
